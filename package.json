{
  "name": "syncops",
  "private": true,
  "version": "0.1.0",
  "description": "SyncOps ERP scaffold - From Demand to Delivery",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace frontend",
    "dev:frontend": "npm run dev --workspace frontend",
    "dev:backend": "npm run dev --workspace backend",
    "lint": "npm run lint --workspaces",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "husky": "^9.1.7",
    "prettier": "^3.3.3",
    "typescript-eslint": "^8.15.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
